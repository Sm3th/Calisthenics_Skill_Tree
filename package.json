{
  "name": "calisthenics-skill-tree",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Interactive calisthenics / street workout progression skill tree",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
